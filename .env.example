# Supabase Configuration (API Keys v2)
# Récupérez ces valeurs dans Supabase : Settings > API

# URL de votre projet
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Publishable Key (clé publique)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Secret Key (optionnel - pour usage serveur uniquement)
SUPABASE_SECRET_KEY=your_supabase_secret_key

# Meta Pixel (Facebook Pixel) — tracking publicitaire / audiences Meta Ads
# Le pixel ne se charge que si l'utilisateur a accepté la catégorie "Marketing"
# du bandeau cookies (RGPD). Laissez vide pour désactiver complètement.
NEXT_PUBLIC_META_PIXEL_ID=your_pixel_id_here

# === Téléconsultation Daily.co ===
# Clé API Daily.co pour créer rooms privées + meeting tokens (HDS / RGPD)
DAILY_API_KEY=
# Sous-domaine Daily.co (ex: "neurocare" pour neurocare.daily.co)
DAILY_DOMAIN=

# === SMS rappels RDV (Twilio) ===
# Compte Twilio pour envoyer les SMS de rappel 24h et 1h avant chaque RDV
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Numéro Twilio expéditeur (format E.164, ex: +33XXXXXXXXX)
TWILIO_PHONE_NUMBER=

# === Cron jobs Vercel ===
# Secret partagé pour authentifier les requêtes du cron Vercel
CRON_SECRET=
