# Supabase Configuration (API Keys v2)
# Récupérez ces valeurs dans Supabase : Settings > API

# URL de votre projet
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Publishable Key (clé publique)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Secret Key (optionnel - pour usage serveur uniquement)
SUPABASE_SECRET_KEY=your_supabase_secret_key

# === Supabase HDS (programme audit famille 2026) ===
# Instance Supabase dédiée aux données de santé (schema `health.*`).
# En staging/local : laisser vide → fallback sur le Supabase général.
# En production : doit pointer sur un Supabase auto-hébergé chez un certifié HDS
# (Scaleway / OVH) avant l'activation des feature flags HDS-sensibles.
NEXT_PUBLIC_SUPABASE_HDS_URL=
NEXT_PUBLIC_SUPABASE_HDS_PUBLISHABLE_KEY=
SUPABASE_HDS_SECRET_KEY=

# === Feature flags audit famille 2026 ===
# Non-HDS : ON par défaut, mettre à "false" pour désactiver.
NEXT_PUBLIC_FEATURE_ONBOARDING_POSTDIAG=
NEXT_PUBLIC_FEATURE_RAPPELS_MDPH=
NEXT_PUBLIC_FEATURE_COURRIERS_ADMIN=
NEXT_PUBLIC_FEATURE_JUSTIFICATIFS_ANNUELS=
NEXT_PUBLIC_FEATURE_ANNUAIRE_EXTERNE=
NEXT_PUBLIC_FEATURE_SCOLARITE=
# HDS-sensibles : OFF par défaut, mettre à "true" pour activer.
# À NE PAS activer en prod tant que l'infra HDS n'est pas provisionnée.
NEXT_PUBLIC_FEATURE_JOURNAL_BORD=
NEXT_PUBLIC_FEATURE_COFFRE_FORT_SANTE=

# Meta Pixel (Facebook Pixel) — tracking publicitaire / audiences Meta Ads
# Le pixel ne se charge que si l'utilisateur a accepté la catégorie "Marketing"
# du bandeau cookies (RGPD). Laissez vide pour désactiver complètement.
NEXT_PUBLIC_META_PIXEL_ID=your_pixel_id_here

# === Téléconsultation Daily.co ===
# Clé API Daily.co pour créer rooms privées + meeting tokens (HDS / RGPD)
DAILY_API_KEY=
# Sous-domaine Daily.co (ex: "neurocare" pour neurocare.daily.co)
DAILY_DOMAIN=

# === SMS rappels RDV (Twilio) ===
# Compte Twilio pour envoyer les SMS de rappel 24h et 1h avant chaque RDV
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Numéro Twilio expéditeur (format E.164, ex: +33XXXXXXXXX)
TWILIO_PHONE_NUMBER=

# === Cron jobs Vercel ===
# Secret partagé pour authentifier les requêtes du cron Vercel
CRON_SECRET=

# === Google Calendar 2-way sync ===
# OAuth credentials (Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Doit matcher exactement une des "URI de redirection autorisés" sur la console Google
GOOGLE_REDIRECT_URI=https://neuro-care.fr/api/auth/google/callback
